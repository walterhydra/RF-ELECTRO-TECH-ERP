# --- Server Configuration ---
NODE_ENV=development
PORT=3001
API_PREFIX=/api/v1
APP_NAME="RF Electro PCB ERP Backend"

# --- Database (PostgreSQL / Prisma) ---
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/pcb_erp_db?schema=public"
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# --- Authentication & JWT ---
JWT_ACCESS_SECRET="super-secret-access-key-change-in-production-2026"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-in-production-2026"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
PORTAL_JWT_SECRET="separate-portal-secret-key-change-in-production-2026"
PORTAL_JWT_EXPIRATION="2h"

# --- File Storage ---
S3_BUCKET="rf-electro-erp-assets"
S3_REGION="ap-south-1"
S3_ACCESS_KEY_ID="your_s3_access_key"
S3_SECRET_ACCESS_KEY="your_s3_secret_key"
S3_ENDPOINT="https://s3.ap-south-1.amazonaws.com"

# --- Notifications ---
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
SMTP_FROM="noreply@rfelectro.com"
SMS_PROVIDER_KEY="your_sms_gateway_key"

# --- Security & Rate Limiting ---
CORS_ORIGINS="http://localhost:3000,http://localhost:3002,https://app.rfelectro.com,https://portal.rfelectro.com"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX_REQUESTS=120
